# Kalshi Weather Engine example configuration

# Account
ACCOUNT_SIZE=5000

# Kalshi credentials
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem

# Lane controls
FORECAST_LANE_ACTIVE=true
FORECAST_AUTONOMOUS_ENABLED=true
SHADOW_EXECUTION=false
KALSHI_SAME_EVENT_FAMILY_CAP=5
KALSHI_HUB_EXPOSURE_PCT=0.30
KALSHI_HUB_EXPOSURE_MIN_USD=40
KALSHI_TAKER_FEE_RATE=0.07
KALSHI_MAKER_FEE_RATE=0.0175

# Optional AI/oracle key
GOOGLE_API_KEY=

# Optional premium ensemble key.
# If blank, the engine automatically falls back to deterministic GFS/ECMWF/GraphCast forecasts.
OPEN_METEO_API_KEY=

# Telegram operator channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO

# Weather provider cadence / backpressure
WEATHER_ACTIVE_CITY_REFRESH_SEC=300
WEATHER_ENSEMBLE_COOLDOWN_SEC=1200
WEATHER_ENSEMBLE_MODEL_PAUSE_SEC=0.75

# Optional: move writable runtime state off the repo or onto an external volume
# ALGO_RUNTIME_DIR=/Volumes/ExternalSSD/kalshi-runtime
# DB_PATH=trades.db
# BOT_LOG_PATH=bot.log
# FORECAST_LOG_PATH=forecast.log
# MIN_FREE_DISK_MB=2048
