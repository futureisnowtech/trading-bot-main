{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre_bash_blocker.sh",
            "timeout": 60,
            "statusMessage": "Safety check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre_edit_protector.sh",
            "timeout": 10,
            "statusMessage": "Checking protected files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post_cmd_logger.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post_py_linter.sh",
            "timeout": 30,
            "statusMessage": "Linting..."
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post_test_runner.sh",
            "timeout": 90,
            "statusMessage": "Running targeted tests..."
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/reload_on_change.sh",
            "timeout": 15,
            "statusMessage": "Scheduling bot reload..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/stop_auto_commit.sh",
            "timeout": 90,
            "statusMessage": "Committing changes..."
          }
        ]
      }
    ]
  }
}
