# ═══════════════════════════════════════════════════════════
# SYSTEM MODE
# ═══════════════════════════════════════════════════════════
PAPER_TRADING=true

# ═══════════════════════════════════════════════════════════
# ACCOUNT
# ═══════════════════════════════════════════════════════════
ACCOUNT_SIZE=5000
EQUITY_POSITION_SIZE_USD=75
CRYPTO_POSITION_SIZE_USD=50

# ═══════════════════════════════════════════════════════════
# AI — ANTHROPIC (console.anthropic.com)
# ═══════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════════════
# NEWS FEED — CryptoPanic (cryptopanic.com/developers/api/)
# Free tier available. RSS fallback used if blank.
# ═══════════════════════════════════════════════════════════
CRYPTOPANIC_API_KEY=

# ═══════════════════════════════════════════════════════════
# REDDIT SENTIMENT (optional — graceful fallback if blank)
# Get free credentials: reddit.com/prefs/apps → create app (script type)
# ═══════════════════════════════════════════════════════════
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AlgoTradingBot/1.0

# ═══════════════════════════════════════════════════════════
# GOKU — Ultra Instinct final debate synthesizer
# GOKU_ENABLED=true activates the 6th agent who runs last with absolute veto/boost
# ═══════════════════════════════════════════════════════════
GOKU_ENABLED=true

# ═══════════════════════════════════════════════════════════
# WEBULL (equity broker)
# ═══════════════════════════════════════════════════════════
WEBULL_USERNAME=
WEBULL_PASSWORD=
WEBULL_TRADE_PIN=
WEBULL_MFA=
WEBULL_DEVICE_ID=algo_bot_001

# ═══════════════════════════════════════════════════════════
# COINBASE (crypto broker — needs "Advanced Trade" scope: View+Trade)
# ═══════════════════════════════════════════════════════════
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ═══════════════════════════════════════════════════════════
# TRADOVATE (MES futures — optional, set FUTURES_ENABLED=true to activate)
# ═══════════════════════════════════════════════════════════
FUTURES_ENABLED=false
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_DEVICE_ID=algo_bot_001

# ═══════════════════════════════════════════════════════════
# CRYPTO PAIRS
# ═══════════════════════════════════════════════════════════
CRYPTO_PAIRS=BTC-USDC,ETH-USDC

# ═══════════════════════════════════════════════════════════
# TELEGRAM ALERTS (optional — dashboard always works without this)
# Setup: t.me/BotFather → /newbot → copy token
# Chat ID: message @userinfobot on Telegram to get your chat_id
# ═══════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════
# LANE 3 — PREDICTION MARKETS
# Enable: set LANE3_ENABLED=true, POLYMARKET_ENABLED=true, KALSHI_ENABLED=true
# Paper mode first — no keys needed for Polymarket price discovery
# Kalshi paper: register at demo.kalshi.co for demo API keys
# ═══════════════════════════════════════════════════════════
LANE3_ENABLED=false
POLYMARKET_ENABLED=false
KALSHI_ENABLED=false
POLYMARKET_PAPER=true
KALSHI_PAPER=true

# Polymarket CLOB (live trading — needs Polygon wallet + API keys from polymarket.com)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_CHAIN_ID=137

# Kalshi (paper: demo-api.kalshi.co — register free at kalshi.com)
KALSHI_API_KEY=
KALSHI_API_SECRET=

# Multi-LLM ensemble (Claude always active via ANTHROPIC_API_KEY above)
# Add these keys to enable GPT-4o and Gemini for ensemble voting
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ═══════════════════════════════════════════════════════════
# BACKTESTING
# ═══════════════════════════════════════════════════════════
BACKTEST_SLIPPAGE_PCT=0.001  # 0.1% per leg; overrides config.py default

# ═══════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════
LOG_LEVEL=INFO
