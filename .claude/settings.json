{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre_bash_blocker.sh",
            "timeout": 60,
            "statusMessage": "Safety check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre_edit_protector.sh",
            "timeout": 10,
            "statusMessage": "Checking protected files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_cmd_logger.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_py_linter.sh",
            "timeout": 30,
            "statusMessage": "Linting..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post_test_runner.sh",
            "timeout": 90,
            "statusMessage": "Running targeted tests..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // \"\"' | { read -r f; [[ \"$f\" =~ ^/Users/joshmacbookair2020/Desktop/algo_trading_final/.*\\.py$ ]] && /Users/joshmacbookair2020/Desktop/algo_trading_final/scripts/reload_on_change.sh; } 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Scheduling bot reload..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop_auto_commit.sh",
            "timeout": 90,
            "statusMessage": "Committing changes..."
          }
        ]
      }
    ]
  }
}
